# Voice Clone Studio - Backend Configuration

# App
APP_NAME="Voice Clone Studio"
DEBUG=true

# Database
DATABASE_URL=sqlite:///./voice_clone.db

# 千问 API (请填入你的 API Key)
QWEN_API_KEY=1
QWEN_MODEL=cosyvoice-v3.5-plus

# MiMo TTS API (小米 MiMo-V2.5-TTS 系列，请填入你的 API Key)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# 日志配置
LOG_LEVEL=INFO  # 可选：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE=true
LOG_FILE_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=7  # 保留 7 个备份文件

# qiniu obs related cofig
BUCKET_DOMAIN=
BUCKET_NAME=
OSS_AK=
OSS_SK=