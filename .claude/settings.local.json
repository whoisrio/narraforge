{
  "permissions": {
    "allow": [
      "mcp__context7__resolve-library-id",
      "WebFetch(domain:help.aliyun.com)",
      "WebSearch",
      "Bash(curl:*)",
      "Bash(cd:*)",
      "Bash(openspec status:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ]
  }
}
