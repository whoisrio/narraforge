{
  "permissions": {
    "allow": [
      "mcp__context7__resolve-library-id",
      "WebFetch(domain:help.aliyun.com)",
      "WebSearch",
      "Bash(curl:*)",
      "Bash(cd:*)",
      "Bash(openspec status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npx vitest *)",
      "Bash(npm install *)",
      "Bash(npm test *)",
      "Bash(.venv/Scripts/python -m pytest tests/integration/test_tts_api.py::TestTTSAPI::test_synthesize_speech_with_defaults -v --tb=long)",
      "Bash(.venv/Scripts/python -m pytest tests/integration/test_tts_api.py -v --tb=short -p no:warnings)",
      "Bash(.venv/Scripts/python *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ]
  }
}
